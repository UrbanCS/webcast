Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteRule ^(?:app|config|database|docs|storage)(?:/|$) - [F,L]
RewriteRule ^(?:README\.md|\.gitignore)$ - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^event/([A-Za-z0-9-]+)/?$ event.php?slug=$1 [L,QSA]
RewriteRule ^admin/?$ admin/index.php [L,QSA]
RewriteRule ^admin/events/?$ admin/events/index.php [L,QSA]
RewriteRule ^admin/events/create/?$ admin/events/create/index.php [L,QSA]
RewriteRule ^admin/events/edit/?$ admin/events/edit/index.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
